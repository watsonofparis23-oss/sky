<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/components.css">
    <link rel="stylesheet" href="/css/responsive.css">
</head>
<body>
    <!-- Hero Section -->
    <section class="hero-section">
        <div class="hero-content">
            <div class="hero-text">
                <h1 class="hero-title">Find Your Perfect Flight</h1>
                <p class="hero-subtitle">Search, compare and book flights with our AI-powered platform. Get the best deals to over 200+ countries worldwide.</p>
                
                <!-- Reciprocity: Free benefit offer -->
                <div class="free-benefit">
                    <i class="fas fa-gift"></i>
                    <span>Free lounge access on all international flights booked today!</span>
                </div>
                
                <!-- Social proof -->
                <div class="social-proof">
                    <i class="fas fa-users"></i>
                    <span>2,345 travelers booked with us in the last 24 hours</span>
                </div>
            </div>
            
            <div class="hero-search">
                <div class="search-container">
                    <div class="search-tabs">
                        <div class="search-tab active" data-type="round-trip">
                            <i class="fas fa-exchange-alt"></i>
                            <span>Round Trip</span>
                        </div>
                        <div class="search-tab" data-type="one-way">
                            <i class="fas fa-arrow-right"></i>
                            <span>One Way</span>
                        </div>
                        <div class="search-tab" data-type="multicity">
                            <i class="fas fa-route"></i>
                            <span>Multicity</span>
                        </div>
                    </div>
                    
                    <form class="search-form" action="/flights/search" method="GET">
                        <div class="search-row">
                            <div class="search-field">
                                <label for="from"><i class="fas fa-map-marker-alt"></i> From</label>
                                <input type="text" id="from" name="from" placeholder="Departure City" value="New York (JFK)" required>
                            </div>
                            <div class="search-field">
                                <label for="to"><i class="fas fa-map-marker"></i> To</label>
                                <input type="text" id="to" name="to" placeholder="Arrival City" value="London (LHR)" required>
                            </div>
                            <div class="search-field">
                                <label for="departure"><i class="fas fa-calendar-alt"></i> Departure</label>
                                <input type="date" id="departure" name="departure" required>
                            </div>
                            <div class="search-field" id="returnField">
                                <label for="return"><i class="fas fa-calendar-check"></i> Return</label>
                                <input type="date" id="return" name="return">
                            </div>
                            <div class="search-field">
                                <label for="passengers"><i class="fas fa-users"></i> Travelers</label>
                                <select id="passengers" name="passengers">
                                    <option value="1">1 Adult</option>
                                    <option value="2">2 Adults</option>
                                    <option value="3" selected>2 Adults, 1 Child</option>
                                    <option value="4">2 Adults, 2 Children</option>
                                    <option value="5">3+ Adults</option>
                                </select>
                            </div>
                            <div class="search-field">
                                <label for="class"><i class="fas fa-couch"></i> Class</label>
                                <select id="class" name="class">
                                    <option value="economy">Economy</option>
                                    <option value="premium">Premium Economy</option>
                                    <option value="business" selected>Business</option>
                                    <option value="first">First Class</option>
                                </select>
                            </div>
                        </div>
                        
                        <button type="submit" class="search-btn">
                            <i class="fas fa-search"></i>
                            Search Flights
                        </button>
                        
                        <!-- Trust badges -->
                        <div class="trust-badges">
                            <div class="trust-badge">
                                <i class="fas fa-shield-alt"></i>
                                <span>Secure Booking</span>
                            </div>
                            <div class="trust-badge">
                                <i class="fas fa-lock"></i>
                                <span>SSL Encryption</span>
                            </div>
                            <div class="trust-badge">
                                <i class="fas fa-star"></i>
                                <span>4.8/5 Rating</span>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
        <div class="container">
            <div class="stats-grid">
                <div class="stat-item">
                    <div class="stat-icon">
                        <i class="fas fa-plane"></i>
                    </div>
                    <div class="stat-content">
                        <h3>500+</h3>
                        <p>Airlines Worldwide</p>
                    </div>
                </div>
                <div class="stat-item">
                    <div class="stat-icon">
                        <i class="fas fa-globe"></i>
                    </div>
                    <div class="stat-content">
                        <h3>200+</h3>
                        <p>Countries Covered</p>
                    </div>
                </div>
                <div class="stat-item">
                    <div class="stat-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-content">
                        <h3>2M+</h3>
                        <p>Happy Travelers</p>
                    </div>
                </div>
                <div class="stat-item">
                    <div class="stat-icon">
                        <i class="fas fa-star"></i>
                    </div>
                    <div class="stat-content">
                        <h3>4.8/5</h3>
                        <p>Customer Rating</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

