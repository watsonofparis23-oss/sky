<%- include('../layouts/main') %>

<div class="dashboard">
    <!-- Hero Section -->
    <div class="hero-section">
        <div class="hero-content">
            <h1 class="hero-title">Welcome back, <%= user.first_name %>!</h1>
            <p class="hero-subtitle">Manage your flights, discover new destinations, and make the most of your travel experience.</p>
            
            <!-- Reciprocity: Free benefit offer -->
            <div class="free-benefit">
                <i class="fas fa-gift"></i>
                <span>Free lounge access on all international flights booked today!</span>
            </div>
            
            <!-- Social proof -->
            <div class="social-proof">
                <i class="fas fa-users"></i>
                <span>2,345 travelers booked with us in the last 24 hours</span>
            </div>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="stats-cards">
        <div class="stat-card">
            <div class="stat-icon blue">
                <i class="fas fa-plane"></i>
            </div>
            <div class="stat-info">
                <h3><%= stats.total_bookings %></h3>
                <p>Total Bookings</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon orange">
                <i class="fas fa-coins"></i>
            </div>
            <div class="stat-info">
                <h3><%= user.loyalty_points || 0 %></h3>
                <p>Loyalty Points</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon green">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-info">
                <h3><%= stats.confirmed_bookings %></h3>
                <p>Confirmed Flights</p>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon red">
                <i class="fas fa-clock"></i>
            </div>
            <div class="stat-info">
                <h3><%= stats.pending_bookings %></h3>
                <p>Pending Bookings</p>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="quick-actions">
        <h2 class="section-title">
            <i class="fas fa-bolt"></i>
            Quick Actions
        </h2>
        <div class="actions-grid">
            <a href="/flights/search" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-search"></i>
                </div>
                <h3>Search Flights</h3>
                <p>Find and book your next flight</p>
            </a>
            <a href="/user/trips" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-suitcase"></i>
                </div>
                <h3>My Trips</h3>
                <p>View and manage your bookings</p>
            </a>
            <a href="/user/travel-journey" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-route"></i>
                </div>
                <h3>Travel Journey</h3>
                <p>Plan your upcoming trips</p>
            </a>
            <a href="/user/ai-packing" class="action-card">
                <div class="action-icon">
                    <i class="fas fa-robot"></i>
                </div>
                <h3>AI Packing</h3>
                <p>Get personalized packing lists</p>
            </a>
        </div>
    </div>

    <!-- Upcoming Flights -->
    <div class="widgets">
        <div class="main-widget">
            <div class="widget-header">
                <h2>Upcoming Flights</h2>
                <a href="/user/flights" class="view-all">View All <i class="fas fa-arrow-right"></i></a>
            </div>
            <div class="flights-list">
                <% if (upcomingFlights.length > 0) { %>
                    <% upcomingFlights.forEach(flight => { %>
                        <div class="flight-card">
                            <div class="flight-info">
                                <div class="flight-route">
                                    <div class="flight-destination"><%= flight.origin_city %> (<%= flight.origin_airport %>) → <%= flight.destination_city %> (<%= flight.destination_airport %>)</div>
                                    <div class="flight-date"><%= new Date(flight.departure_time).toLocaleDateString() %> • <%= new Date(flight.departure_time).toLocaleTimeString() %></div>
                                </div>
                                <div class="flight-details">
                                    <span>Flight #<%= flight.flight_number %></span>
                                    <span>Airline: <%= flight.airline_name %></span>
                                    <span>Class: <%= flight.booking_class %></span>
                                </div>
                            </div>
                            <div class="flight-status status-confirmed">Confirmed</div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fas fa-plane"></i>
                        <h3>No upcoming flights</h3>
                        <p>Start planning your next adventure!</p>
                        <a href="/flights/search" class="btn-primary">Search Flights</a>
                    </div>
                <% } %>
            </div>
        </div>
        
        <div class="side-widget">
            <div class="widget-header">
                <h2>Special Deals</h2>
                <a href="/user/discover" class="view-all">View All <i class="fas fa-arrow-right"></i></a>
            </div>
            <div class="deals-container">
                <% if (deals.length > 0) { %>
                    <% deals.forEach(deal => { %>
                        <div class="deal-card">
                            <div class="deal-image">
                                <i class="fas fa-percent"></i>
                            </div>
                            <div class="deal-info">
                                <h3><%= deal.title %></h3>
                                <p><%= deal.description %></p>
                                <div class="deal-discount">
                                    <% if (deal.discount_type === 'percentage') { %>
                                        <%= deal.discount_value %>% OFF
                                    <% } else { %>
                                        $<%= deal.discount_value %> OFF
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="empty-state">
                        <i class="fas fa-tag"></i>
                        <h3>No current deals</h3>
                        <p>Check back later for special offers!</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="recent-activity">
        <h2 class="section-title">
            <i class="fas fa-history"></i>
            Recent Activity
        </h2>
        <div class="activity-list">
            <% if (recentBookings.length > 0) { %>
                <% recentBookings.slice(0, 5).forEach(booking => { %>
                    <div class="activity-item">
                        <div class="activity-icon">
                            <i class="fas fa-plane"></i>
                        </div>
                        <div class="activity-content">
                            <h4>Flight Booking</h4>
                            <p><%= booking.origin_city %> to <%= booking.destination_city %></p>
                            <span class="activity-time"><%= new Date(booking.booking_date).toLocaleDateString() %></span>
                        </div>
                        <div class="activity-status">
                            <span class="status-badge status-<%= booking.status %>"><%= booking.status %></span>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="empty-state">
                    <i class="fas fa-clock"></i>
                    <h3>No recent activity</h3>
                    <p>Your booking history will appear here</p>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Travel Tips -->
    <div class="travel-tips">
        <h2 class="section-title">
            <i class="fas fa-lightbulb"></i>
            Travel Tips
        </h2>
        <div class="tips-grid">
            <div class="tip-card">
                <div class="tip-icon">
                    <i class="fas fa-passport"></i>
                </div>
                <h3>Check Passport Validity</h3>
                <p>Ensure your passport is valid for at least 6 months from your travel date.</p>
            </div>
            <div class="tip-card">
                <div class="tip-icon">
                    <i class="fas fa-suitcase"></i>
                </div>
                <h3>Pack Smart</h3>
                <p>Use our AI packing list generator to ensure you don't forget anything important.</p>
            </div>
            <div class="tip-card">
                <div class="tip-icon">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h3>Travel Insurance</h3>
                <p>Consider purchasing travel insurance for peace of mind during your journey.</p>
            </div>
        </div>
    </div>
</div>

<style>
/* Dashboard Specific Styles */
.dashboard {
    padding: 20px;
}

.hero-section {
    background: var(--gradient-secondary);
    border-radius: 20px;
    padding: 40px;
    margin-bottom: 30px;
    color: white;
    position: relative;
    overflow: hidden;
}

.hero-content h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 15px;
}

.hero-content p {
    font-size: 1.1rem;
    margin-bottom: 20px;
    opacity: 0.9;
}

.stats-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.stat-card {
    background: var(--secondary-bg);
    border-radius: 15px;
    padding: 20px;
    box-shadow: var(--card-shadow);
    display: flex;
    align-items: center;
    gap: 15px;
    transition: var(--transition);
    border: 1px solid rgba(255,255,255,0.05);
}

.stat-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--card-shadow-hover);
}

.stat-icon {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
}

.stat-icon.blue {
    background: rgba(37, 99, 235, 0.1);
    color: var(--primary);
}

.stat-icon.orange {
    background: rgba(249, 115, 22, 0.1);
    color: var(--secondary);
}

.stat-icon.green {
    background: rgba(16, 185, 129, 0.1);
    color: var(--success);
}

.stat-icon.red {
    background: rgba(239, 68, 68, 0.1);
    color: var(--danger);
}

.stat-info h3 {
    font-size: 1.5rem;
    margin-bottom: 5px;
    font-weight: 700;
}

.stat-info p {
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.quick-actions {
    margin-bottom: 30px;
}

.section-title {
    font-size: 1.8rem;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-primary);
}

.section-title i {
    color: var(--accent-secondary);
}

.actions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
}

.action-card {
    background: var(--secondary-bg);
    border-radius: 15px;
    padding: 25px;
    text-align: center;
    text-decoration: none;
    color: var(--text-primary);
    transition: var(--transition);
    border: 1px solid rgba(255,255,255,0.05);
}

.action-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--card-shadow-hover);
    border-color: var(--primary);
}

.action-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--gradient-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 15px;
    font-size: 1.5rem;
    color: white;
}

.action-card h3 {
    font-size: 1.1rem;
    margin-bottom: 10px;
    font-weight: 600;
}

.action-card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.widgets {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 20px;
    margin-bottom: 30px;
}

.main-widget, .side-widget {
    background: var(--secondary-bg);
    border-radius: 15px;
    padding: 25px;
    box-shadow: var(--card-shadow);
    transition: var(--transition);
    border: 1px solid rgba(255,255,255,0.05);
}

.widget-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    padding-bottom: 15px;
    border-bottom: 1px solid var(--card-bg);
}

.widget-header h2 {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text-primary);
}

.view-all {
    color: var(--primary);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 5px;
}

.view-all:hover {
    text-decoration: underline;
}

.flight-card {
    display: flex;
    align-items: center;
    padding: 20px;
    border: 1px solid var(--card-bg);
    border-radius: 12px;
    margin-bottom: 15px;
    transition: var(--transition);
    cursor: pointer;
    background: var(--secondary-bg);
}

.flight-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
    border-color: var(--primary);
}

.flight-info {
    flex: 1;
    min-width: 0;
}

.flight-route {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
    flex-wrap: wrap;
    gap: 10px;
}

.flight-destination {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--text-primary);
}

.flight-date {
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.flight-details {
    display: flex;
    gap: 15px;
    color: var(--text-secondary);
    font-size: 0.9rem;
    flex-wrap: wrap;
}

.flight-status {
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: bold;
    white-space: nowrap;
}

.status-confirmed {
    background: rgba(16, 185, 129, 0.1);
    color: var(--success);
}

.status-pending {
    background: rgba(249, 115, 22, 0.1);
    color: var(--warning);
}

.deals-container {
    display: grid;
    gap: 15px;
}

.deal-card {
    display: flex;
    gap: 15px;
    padding: 15px;
    border-radius: 12px;
    background: var(--card-bg);
    transition: var(--transition);
    cursor: pointer;
    border: 1px solid transparent;
}

.deal-card:hover {
    background: var(--secondary-bg);
    transform: translateX(5px);
    box-shadow: var(--card-shadow);
    border-color: var(--primary);
}

.deal-image {
    width: 60px;
    height: 60px;
    border-radius: 10px;
    background: var(--gradient-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.5rem;
    flex-shrink: 0;
}

.deal-info h3 {
    font-size: 1rem;
    margin-bottom: 5px;
    font-weight: 600;
}

.deal-info p {
    color: var(--text-secondary);
    font-size: 0.8rem;
    margin-bottom: 8px;
}

.deal-discount {
    color: var(--accent);
    font-weight: 600;
    font-size: 0.9rem;
}

.empty-state {
    text-align: center;
    padding: 40px 20px;
    color: var(--text-secondary);
}

.empty-state i {
    font-size: 3rem;
    margin-bottom: 15px;
    color: var(--gray);
}

.empty-state h3 {
    font-size: 1.2rem;
    margin-bottom: 10px;
    color: var(--text-primary);
}

.empty-state p {
    margin-bottom: 20px;
}

.recent-activity {
    margin-bottom: 30px;
}

.activity-list {
    background: var(--secondary-bg);
    border-radius: 15px;
    padding: 25px;
    box-shadow: var(--card-shadow);
}

.activity-item {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px 0;
    border-bottom: 1px solid var(--card-bg);
}

.activity-item:last-child {
    border-bottom: none;
}

.activity-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--card-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    flex-shrink: 0;
}

.activity-content {
    flex: 1;
}

.activity-content h4 {
    font-size: 1rem;
    margin-bottom: 5px;
    color: var(--text-primary);
}

.activity-content p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 5px;
}

.activity-time {
    color: var(--text-secondary);
    font-size: 0.8rem;
}

.activity-status {
    flex-shrink: 0;
}

.status-badge {
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 600;
}

.status-confirmed {
    background: rgba(16, 185, 129, 0.1);
    color: var(--success);
}

.status-pending {
    background: rgba(249, 115, 22, 0.1);
    color: var(--warning);
}

.travel-tips {
    margin-bottom: 30px;
}

.tips-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
}

.tip-card {
    background: var(--secondary-bg);
    border-radius: 15px;
    padding: 25px;
    box-shadow: var(--card-shadow);
    transition: var(--transition);
    border: 1px solid rgba(255,255,255,0.05);
}

.tip-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--card-shadow-hover);
}

.tip-icon {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    background: rgba(37, 99, 235, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 15px;
    color: var(--primary);
    font-size: 1.2rem;
}

.tip-card h3 {
    font-size: 1.1rem;
    margin-bottom: 10px;
    font-weight: 600;
    color: var(--text-primary);
}

.tip-card p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
}

@media (max-width: 768px) {
    .widgets {
        grid-template-columns: 1fr;
    }
    
    .stats-cards {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .actions-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .tips-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 576px) {
    .stats-cards {
        grid-template-columns: 1fr;
    }
    
    .actions-grid {
        grid-template-columns: 1fr;
    }
}
</style>