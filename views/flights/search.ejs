<%- include('../layouts/main') %>

<div class="search-page">
    <!-- Search Form -->
    <div class="search-container">
        <div class="search-header">
            <h1>Search Flights</h1>
            <p>Find the best deals on flights worldwide</p>
        </div>
        
        <form class="search-form" action="/flights/results" method="GET">
            <div class="search-tabs">
                <div class="search-tab active" data-type="round-trip">
                    <i class="fas fa-exchange-alt"></i>
                    <span>Round Trip</span>
                </div>
                <div class="search-tab" data-type="one-way">
                    <i class="fas fa-arrow-right"></i>
                    <span>One Way</span>
                </div>
                <div class="search-tab" data-type="multicity">
                    <i class="fas fa-route"></i>
                    <span>Multicity</span>
                </div>
            </div>
            
            <div class="search-row">
                <div class="search-field">
                    <label for="from"><i class="fas fa-map-marker-alt"></i> From</label>
                    <input type="text" id="from" name="from" placeholder="Departure City" value="<%= searchParams.from %>" required>
                </div>
                <div class="search-field">
                    <label for="to"><i class="fas fa-map-marker"></i> To</label>
                    <input type="text" id="to" name="to" placeholder="Arrival City" value="<%= searchParams.to %>" required>
                </div>
                <div class="search-field">
                    <label for="departure"><i class="fas fa-calendar-alt"></i> Departure</label>
                    <input type="date" id="departure" name="departure" value="<%= searchParams.departure %>" required>
                </div>
                <div class="search-field" id="returnField">
                    <label for="return"><i class="fas fa-calendar-check"></i> Return</label>
                    <input type="date" id="return" name="return" value="<%= searchParams.return %>">
                </div>
                <div class="search-field">
                    <label for="passengers"><i class="fas fa-users"></i> Travelers</label>
                    <select id="passengers" name="passengers">
                        <option value="1" <%= searchParams.passengers === '1' ? 'selected' : '' %>>1 Adult</option>
                        <option value="2" <%= searchParams.passengers === '2' ? 'selected' : '' %>>2 Adults</option>
                        <option value="3" <%= searchParams.passengers === '3' ? 'selected' : '' %>>2 Adults, 1 Child</option>
                        <option value="4" <%= searchParams.passengers === '4' ? 'selected' : '' %>>2 Adults, 2 Children</option>
                        <option value="5" <%= searchParams.passengers === '5' ? 'selected' : '' %>>3+ Adults</option>
                    </select>
                </div>
                <div class="search-field">
                    <label for="class"><i class="fas fa-couch"></i> Class</label>
                    <select id="class" name="class">
                        <option value="economy" <%= searchParams.class === 'economy' ? 'selected' : '' %>>Economy</option>
                        <option value="premium" <%= searchParams.class === 'premium' ? 'selected' : '' %>>Premium Economy</option>
                        <option value="business" <%= searchParams.class === 'business' ? 'selected' : '' %>>Business</option>
                        <option value="first" <%= searchParams.class === 'first' ? 'selected' : '' %>>First Class</option>
                    </select>
                </div>
            </div>
            
            <button type="submit" class="search-btn">
                <i class="fas fa-search"></i>
                Search Flights
            </button>
            
            <!-- Trust badges -->
            <div class="trust-badges">
                <div class="trust-badge">
                    <i class="fas fa-shield-alt"></i>
                    <span>Secure Booking</span>
                </div>
                <div class="trust-badge">
                    <i class="fas fa-lock"></i>
                    <span>SSL Encryption</span>
                </div>
                <div class="trust-badge">
                    <i class="fas fa-star"></i>
                    <span>4.8/5 Rating</span>
                </div>
            </div>
        </form>
    </div>

    <!-- Popular Destinations -->
    <div class="popular-destinations">
        <h2 class="section-title">
            <i class="fas fa-map-marker-alt"></i>
            Popular Destinations
        </h2>
        
        <div class="destinations-grid">
            <div class="destination-card" data-destination="dubai">
                <div class="destination-image">
                    <img src="https://images.unsplash.com/photo-1562602833-72b336fa9e2c?ixlib=rb-1.2.1&auto=format&fit=crop&w=600&q=80" alt="Dubai">
                    <div class="destination-overlay">
                        <div class="fomo-indicator">
                            <i class="fas fa-fire"></i> TRENDING
                        </div>
                    </div>
                </div>
                <div class="destination-content">
                    <h3 class="destination-name">Dubai</h3>
                    <p class="destination-flights">From $499</p>
                    <div class="destination-details">
                        <span><i class="fas fa-plane"></i> 15+ flights daily</span>
                        <span><i class="fas fa-clock"></i> 8h 30m avg</span>
                    </div>
                </div>
            </div>
            
            <div class="destination-card" data-destination="paris">
                <div class="destination-image">
                    <img src="https://images.unsplash.com/photo-1507699622108-4be3abd695ad?ixlib=rb-1.2.1&auto=format&fit=crop&w=600&q=80" alt="Paris">
                    <div class="destination-overlay">
                        <div class="social-proof">
                            <i class="fas fa-user"></i> 2.4K visitors this month
                        </div>
                    </div>
                </div>
                <div class="destination-content">
                    <h3 class="destination-name">Paris</h3>
                    <p class="destination-flights">From $549</p>
                    <div class="destination-details">
                        <span><i class="fas fa-plane"></i> 25+ flights daily</span>
                        <span><i class="fas fa-clock"></i> 7h 15m avg</span>
                    </div>
                </div>
            </div>
            
            <div class="destination-card" data-destination="tokyo">
                <div class="destination-image">
                    <img src="https://images.unsplash.com/photo-1506970840772-503770eb8c51?ixlib=rb-1.2.1&auto=format&fit=crop&w=600&q=80" alt="Tokyo">
                    <div class="destination-overlay">
                        <div class="fomo-indicator">
                            <i class="fas fa-bolt"></i> SALE
                        </div>
                    </div>
                </div>
                <div class="destination-content">
                    <h3 class="destination-name">Tokyo</h3>
                    <p class="destination-flights">From $799</p>
                    <div class="destination-details">
                        <span><i class="fas fa-plane"></i> 12+ flights daily</span>
                        <span><i class="fas fa-clock"></i> 13h 45m avg</span>
                    </div>
                </div>
            </div>
            
            <div class="destination-card" data-destination="singapore">
                <div class="destination-image">
                    <img src="https://images.unsplash.com/photo-1532664189809-02133fee698d?ixlib=rb-1.2.1&auto=format&fit=crop&w=600&q=80" alt="Singapore">
                </div>
                <div class="destination-content">
                    <h3 class="destination-name">Singapore</h3>
                    <p class="destination-flights">From $689</p>
                    <div class="destination-details">
                        <span><i class="fas fa-plane"></i> 8+ flights daily</span>
                        <span><i class="fas fa-clock"></i> 18h 20m avg</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Special Deals -->
    <div class="special-deals">
        <h2 class="section-title">
            <i class="fas fa-percent"></i>
            Special Flight Deals
        </h2>
        
        <!-- Urgency timer -->
        <div class="urgency-timer">
            <i class="fas fa-bolt"></i> FLASH SALE: Ends in 04:18:32
        </div>
        
        <div class="deals-grid">
            <div class="deal-card">
                <div class="deal-badge">Popular</div>
                <div class="deal-image">
                    <img src="https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?ixlib=rb-1.2.1&auto=format&fit=crop&w=600&q=80" alt="Paris">
                </div>
                <div class="deal-content">
                    <h3 class="deal-destination">New York to Paris</h3>
                    <p class="deal-details">Round trip • 7-14 days • Direct flights available</p>
                    
                    <!-- Anchoring: Show original price -->
                    <div class="deal-pricing">
                        <span class="original-price">$899</span>
                        <span class="current-price">$649</span>
                    </div>
                    
                    <!-- Scarcity indicator -->
                    <div class="scarcity-indicator">
                        <i class="fas fa-bolt"></i> 12 seats left at this price
                    </div>
                    
                    <!-- Social proof -->
                    <div class="social-proof">
                        <i class="fas fa-user-check"></i> 43 booked today
                    </div>
                    
                    <button class="deal-btn" onclick="bookDeal('NYC-PAR')">Book Now</button>
                </div>
            </div>
            
            <div class="deal-card">
                <div class="deal-badge">Sale</div>
                <div class="deal-image">
                    <img src="https://images.unsplash.com/photo-1534351590666-13e3e96b5017?ixlib=rb-1.2.1&auto=format&fit=crop&w=600&q=80" alt="Tokyo">
                </div>
                <div class="deal-content">
                    <h3 class="deal-destination">London to Tokyo</h3>
                    <p class="deal-details">Round trip • 10-21 days • 1 stop</p>
                    
                    <!-- Anchoring: Show original price -->
                    <div class="deal-pricing">
                        <span class="original-price">$1,199</span>
                        <span class="current-price">$899</span>
                    </div>
                    
                    <!-- Reciprocity: Free benefit -->
                    <div class="free-benefit">
                        <i class="fas fa-suitcase"></i> Free extra baggage
                    </div>
                    
                    <button class="deal-btn" onclick="bookDeal('LON-TYO')">Book Now</button>
                </div>
            </div>
            
            <div class="deal-card">
                <div class="deal-image">
                    <img src="https://images.unsplash.com/photo-1502602898536-47ad22581b52?ixlib=rb-1.2.1&auto=format&fit=crop&w=600&q=80" alt="Bali">
                </div>
                <div class="deal-content">
                    <h3 class="deal-destination">Sydney to Bali</h3>
                    <p class="deal-details">Round trip • 5-12 days • Direct flights</p>
                    
                    <!-- Social proof -->
                    <div class="social-proof">
                        <i class="fas fa-star"></i> Recommended by 92% of travelers
                    </div>
                    
                    <div class="deal-pricing">
                        <span class="current-price">$429</span>
                    </div>
                    
                    <button class="deal-btn" onclick="bookDeal('SYD-DPS')">Book Now</button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
