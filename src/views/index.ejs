<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="landing-page">
        <header class="landing-header">
            <div class="container">
                <div class="logo">
                    <i class="fas fa-plane"></i>
                    <span>SkyVoyage</span>
                </div>
                <nav>
                    <a href="/auth/login" class="btn-login">Login</a>
                    <a href="/auth/register" class="btn-register">Register</a>
                </nav>
            </div>
        </header>

        <section class="hero">
            <div class="container">
                <h1>Find Your Perfect Flight</h1>
                <p>Search, compare and book flights with our AI-powered platform</p>
                
                <div class="hero-search">
                    <form action="/flights/search" method="GET">
                        <input type="text" name="origin" placeholder="From" required>
                        <input type="text" name="destination" placeholder="To" required>
                        <input type="date" name="departureDate" required>
                        <select name="passengers">
                            <option value="1">1 Passenger</option>
                            <option value="2">2 Passengers</option>
                            <option value="3">3 Passengers</option>
                            <option value="4">4+ Passengers</option>
                        </select>
                        <button type="submit">Search Flights</button>
                    </form>
                </div>
            </div>
        </section>

        <section class="features">
            <div class="container">
                <h2>Why Choose SkyVoyage?</h2>
                <div class="features-grid">
                    <div class="feature">
                        <i class="fas fa-search"></i>
                        <h3>Smart Search</h3>
                        <p>Find the best flights with our intelligent search engine</p>
                    </div>
                    <div class="feature">
                        <i class="fas fa-tags"></i>
                        <h3>Best Prices</h3>
                        <p>Compare prices and get exclusive deals</p>
                    </div>
                    <div class="feature">
                        <i class="fas fa-shield-alt"></i>
                        <h3>Secure Booking</h3>
                        <p>Your data is protected with industry-leading security</p>
                    </div>
                    <div class="feature">
                        <i class="fas fa-headset"></i>
                        <h3>24/7 Support</h3>
                        <p>Our team is always here to help you</p>
                    </div>
                </div>
            </div>
        </section>

        <footer class="landing-footer">
            <div class="container">
                <p>&copy; 2024 SkyVoyage. All rights reserved.</p>
            </div>
        </footer>
    </div>

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; }
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        
        .landing-header {
            background: #1e293b;
            color: white;
            padding: 20px 0;
        }
        .landing-header .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo {
            font-size: 1.5rem;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .logo i { color: #ffab40; }
        
        nav { display: flex; gap: 15px; }
        .btn-login, .btn-register {
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: 500;
        }
        .btn-login {
            color: white;
            border: 1px solid white;
        }
        .btn-register {
            background: #1a73e8;
            color: white;
        }
        
        .hero {
            background: linear-gradient(135deg, #1a73e8 0%, #6c5ce7 100%);
            color: white;
            padding: 100px 0;
            text-align: center;
        }
        .hero h1 {
            font-size: 3rem;
            margin-bottom: 20px;
        }
        .hero p {
            font-size: 1.2rem;
            margin-bottom: 40px;
        }
        
        .hero-search {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            max-width: 800px;
            margin: 0 auto;
        }
        .hero-search form {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
        }
        .hero-search input, .hero-search select {
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 5px;
            font-size: 1rem;
        }
        .hero-search button {
            grid-column: 1 / -1;
            background: #1a73e8;
            color: white;
            border: none;
            padding: 15px;
            border-radius: 5px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
        }
        .hero-search button:hover {
            background: #0d62c9;
        }
        
        .features {
            padding: 80px 0;
            background: #f8fafc;
        }
        .features h2 {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 50px;
        }
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
        }
        .feature {
            text-align: center;
            padding: 30px;
            background: white;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
        .feature i {
            font-size: 3rem;
            color: #1a73e8;
            margin-bottom: 20px;
        }
        .feature h3 {
            font-size: 1.5rem;
            margin-bottom: 15px;
        }
        
        .landing-footer {
            background: #1e293b;
            color: white;
            text-align: center;
            padding: 30px 0;
        }
    </style>
</body>
</html>
